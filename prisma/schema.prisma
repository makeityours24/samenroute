generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum PlaceSourceType {
  MANUAL
  GOOGLE_PLACE
  IMPORTED
}

enum ListPlaceStatus {
  PLANNED
  VISITED
  SKIPPED
}

enum TransportMode {
  DRIVING
  WALKING
  BICYCLING
  TRANSIT
}

enum RoutePlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ActivityEntityType {
  LIST
  PLACE
  ROUTE
  MEMBERSHIP
}

model User {
  id             String        @id @default(uuid())
  email             String         @unique
  name              String?
  avatarUrl      String?        @map("avatar_url")
  emailVerified     DateTime?      @map("email_verified")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  accounts          Account[]
  sessions          Session[]
  ownedLists     List[]        @relation("OwnedLists")
  memberships    ListMember[]
  createdPlaces  Place[]       @relation("CreatedPlaces")
  visitedItems   ListPlace[]   @relation("VisitedByUser")
  routePlans     RoutePlan[]
  activityLogs   ActivityLog[] @relation("ActorLogs")
  sentListInvites ListInvite[] @relation("InvitedByUser")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model List {
  id            String        @id @default(uuid())
  ownerUserId   String        @map("owner_user_id")
  name          String
  description   String?
  coverColor    String?       @map("cover_color")
  isArchived    Boolean       @default(false) @map("is_archived")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  owner         User          @relation("OwnedLists", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members       ListMember[]
  listPlaces    ListPlace[]
  routePlans    RoutePlan[]
  activityLogs  ActivityLog[]
  invites       ListInvite[]

  @@index([ownerUserId])
  @@map("lists")
}

model ListMember {
  id        String         @id @default(uuid())
  listId    String         @map("list_id")
  userId    String         @map("user_id")
  role      ListMemberRole
  createdAt DateTime       @default(now()) @map("created_at")
  list      List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([userId])
  @@map("list_members")
}

model ListInvite {
  id              String         @id @default(uuid())
  listId          String         @map("list_id")
  email           String
  role            ListMemberRole
  invitedByUserId String         @map("invited_by_user_id")
  acceptedAt      DateTime?      @map("accepted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  list            List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  invitedByUser   User           @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([listId, email])
  @@index([email, acceptedAt])
  @@map("list_invites")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  iconName  String?  @map("icon_name")
  createdAt DateTime @default(now()) @map("created_at")
  places    Place[]

  @@map("categories")
}

model Place {
  id               String          @id @default(uuid())
  sourceType       PlaceSourceType @default(MANUAL) @map("source_type")
  externalSourceId String?         @map("external_source_id")
  name             String
  addressLine      String?         @map("address_line")
  postalCode       String?         @map("postal_code")
  city             String?
  country          String?
  latitude         Decimal?        @db.Decimal(9, 6)
  longitude        Decimal?        @db.Decimal(9, 6)
  googleMapsUrl    String?         @map("google_maps_url")
  categoryId       String?         @map("category_id")
  createdByUserId  String          @map("created_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByUser    User            @relation("CreatedPlaces", fields: [createdByUserId], references: [id], onDelete: Restrict)
  listPlaces       ListPlace[]

  @@index([categoryId])
  @@index([createdByUserId])
  @@index([city, country])
  @@index([externalSourceId])
  @@map("places")
}

model ListPlace {
  id              String          @id @default(uuid())
  listId          String          @map("list_id")
  placeId         String          @map("place_id")
  note            String?
  priority        Int             @default(0)
  sortOrder       Int             @default(0) @map("sort_order")
  status          ListPlaceStatus @default(PLANNED)
  visitedAt       DateTime?       @map("visited_at")
  visitedByUserId String?         @map("visited_by_user_id")
  includeInRoute  Boolean         @default(true) @map("include_in_route")
  isFavorite      Boolean         @default(false) @map("is_favorite")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  list            List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  place           Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  visitedByUser   User?           @relation("VisitedByUser", fields: [visitedByUserId], references: [id], onDelete: SetNull)
  routeStops      RoutePlanStop[]

  @@unique([listId, placeId])
  @@index([listId, status])
  @@index([visitedByUserId])
  @@map("list_places")
}

model RoutePlan {
  id              String          @id @default(uuid())
  listId          String          @map("list_id")
  createdByUserId String          @map("created_by_user_id")
  title           String?
  transportMode   TransportMode   @default(DRIVING) @map("transport_mode")
  startPlaceLabel String?         @map("start_place_label")
  startLatitude   Decimal?        @map("start_latitude") @db.Decimal(9, 6)
  startLongitude  Decimal?        @map("start_longitude") @db.Decimal(9, 6)
  googleMapsUrl   String?         @map("google_maps_url")
  status          RoutePlanStatus @default(DRAFT)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  list            List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdByUser   User            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  stops           RoutePlanStop[]

  @@index([listId, status])
  @@index([createdByUserId])
  @@map("route_plans")
}

model RoutePlanStop {
  id          String    @id @default(uuid())
  routePlanId String    @map("route_plan_id")
  listPlaceId String    @map("list_place_id")
  stopOrder   Int       @map("stop_order")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  routePlan   RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  listPlace   ListPlace @relation(fields: [listPlaceId], references: [id], onDelete: Cascade)

  @@index([routePlanId, stopOrder])
  @@unique([routePlanId, stopOrder])
  @@index([listPlaceId])
  @@map("route_plan_stops")
}

model ActivityLog {
  id           String             @id @default(uuid())
  actorUserId  String             @map("actor_user_id")
  listId       String?            @map("list_id")
  entityType   ActivityEntityType @map("entity_type")
  entityId     String             @map("entity_id")
  actionType   String             @map("action_type")
  payloadJson  Json?              @map("payload_json")
  createdAt    DateTime           @default(now()) @map("created_at")
  actorUser    User               @relation("ActorLogs", fields: [actorUserId], references: [id], onDelete: Restrict)
  list         List?              @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@index([listId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("activity_logs")
}
